<?xml version="1.0" encoding="UTF-8"?><record_update sys_domain="global" table="sys_script_client">
    <sys_script_client action="DELETE">
        <active>true</active>
        <applies_extended>false</applies_extended>
        <condition/>
        <description>whenever the laptop type is changed the message about the setup will be displayed on the top.</description>
        <field>laptop_type</field>
        <global>true</global>
        <isolate_script>true</isolate_script>
        <messages/>
        <name>Laptop setup messages</name>
        <order/>
        <script><![CDATA[function onChange(control, oldValue, newValue, isLoading, isTemplate) {
    if (isLoading || newValue == '') {
        return;
    }

    g_form.clearMessages();

    if (newValue == 'MacBook') {
        g_form.addInfoMessage('MacBook setup task will be created automatically after submission.');
    } else if (newValue == 'Windows') {
        g_form.addInfoMessage('Windows device configuration tasks will be generated automatically.');
    } else if (newValue == 'Linux') {
        g_form.addInfoMessage('Linux workstation setup requires additional configuration tasks.');
    }
}]]></script>
